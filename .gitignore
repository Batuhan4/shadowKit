# Node / TS
node_modules/
dist/
build/
.turbo/
*.tsbuildinfo
coverage/

# Rust / Soroban
target/
**/target/
*.wasm

# Circom / snarkjs artifacts (keep committed fixtures under circuits/fixtures/)
