# Node / TS
node_modules/
dist/
build/
.turbo/
*.tsbuildinfo
coverage/

# Rust / Soroban
target/
**/target/
*.wasm

# Circom / snarkjs artifacts (keep committed fixtures under circuits/fixtures/)
*.r1cs
*.zkey
*.ptau
*.wtns
circuits/**/*_js/
circuits/**/*.sym
# Circuit build intermediates (ignored; committed fixtures are force-kept below).
circuits/*/build/
circuits/*/build-min/

# Env / secrets
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# Stellar / local
.stellar/
.soroban/
*.log

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp

# Keep committed circuit fixtures (M4 puts vote.r1cs / vote_final.zkey / verification_key.json here).
# The global *.r1cs / *.zkey / *.ptau / *.wasm ignores above would otherwise hide them — re-include.
!circuits/vote/fixtures/
!circuits/vote/fixtures/*.r1cs
!circuits/vote/fixtures/*.zkey
!circuits/vote/fixtures/*.ptau
!circuits/vote/fixtures/*.json
!circuits/vote/fixtures/*.wasm

# Keep committed DEGRADED (fallback-2) fixtures (Task 4.36: vote_min.r1cs/.wasm/_final.zkey/vk/proof).
!circuits/vote/fixtures-min/
!circuits/vote/fixtures-min/*.r1cs
!circuits/vote/fixtures-min/*.zkey
!circuits/vote/fixtures-min/*.ptau
!circuits/vote/fixtures-min/*.json
!circuits/vote/fixtures-min/*.wasm

# Keep the committed FRESH round-trip bundle (Task 4.35: proof.json/public.json/meta.json).
!circuits/vote/fixtures-fresh/
!circuits/vote/fixtures-fresh/*

# Keep committed BLS12-381 Poseidon parity helper wasms (M4 §0.1).
!circuits/poseidon-helpers/fixtures/
!circuits/poseidon-helpers/fixtures/*.wasm

# Keep committed zk-prover runtime artifacts (helper + vote wasm/zkey/vk for tests & browser proving).
!packages/zk-prover/artifacts/
!packages/zk-prover/artifacts/*.wasm
!packages/zk-prover/artifacts/*.zkey
!packages/zk-prover/artifacts/*.json

# e2e-hero esbuild bundle (transient)
.run-e2e-bundle.mjs

# demo (scripts/demo) transient esbuild bundles + the artifacts symlink they resolve poseidon wasm via
.demo-bundle/
/artifacts
