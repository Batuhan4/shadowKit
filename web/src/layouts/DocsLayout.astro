---
// Docs shell: sticky sidebar nav + content column, on-brand, wraps the site Layout.
// Custom (NOT Starlight) so it matches the site exactly.
import Layout from "./Layout.astro";
import { DOCS_NAV, isCurrent, prevNext } from "../components/docs/docs-nav.ts";

interface Props {
  title: string;
  description?: string;
  /** the active page's href (e.g. "/docs/contracts"); defaults to the request path */
  href?: string;
  /** kicker shown above the page H1 */
  eyebrow?: string;
}
const { title, description, eyebrow, href } = Astro.props;
const path = href ?? Astro.url.pathname;
const { prev, next } = prevNext(path);
const fullTitle = `${title} · ShadowKit Docs`;
---
<Layout title={fullTitle} description={description}>
  <div class="docs container">
    <aside class="sidebar" aria-label="Documentation">
      <a class="docs-home" href="/docs">
        <span class="docs-home-mark" aria-hidden="true">◇</span>
        <span>ShadowKit SDK</span>
      </a>
      <nav class="docs-nav">
        {DOCS_NAV.map((section) => (
          <div class="nav-section">
            <p class="nav-title">{section.title}</p>
            <ul>
              {section.links.map((l) => (
                <li>
                  <a
                    href={l.href}
                    class:list={["nav-link", { active: isCurrent(l.href, path) }]}
                    aria-current={isCurrent(l.href, path) ? "page" : undefined}
                  >
                    {l.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </nav>
    </aside>

    <article class="content">
      <header class="content-head">
        {eyebrow && <span class="eyebrow">{eyebrow}</span>}
        <h1>{title}</h1>
        {description && <p class="content-lede">{description}</p>}
      </header>

      <div class="prose">
        <slot />
      </div>

      <nav class="pager" aria-label="Pagination">
        {prev ? (
          <a class="pager-link prev" href={prev.href}>
            <span class="pager-dir mono">← Prev</span>
            <span class="pager-label">{prev.label}</span>
          </a>
        ) : (
          <span></span>
        )}
        {next ? (
          <a class="pager-link next" href={next.href}>
            <span class="pager-dir mono">Next →</span>
            <span class="pager-label">{next.label}</span>
          </a>
        ) : (
          <span></span>
        )}
      </nav>
    </article>
  </div>
</Layout>

<style>
  .docs {
    display: grid;
    grid-template-columns: 230px minmax(0, 1fr);
    gap: 2.6rem;
    padding-top: 2.2rem;
    padding-bottom: 4rem;
    align-items: start;
  }
  .sidebar {
    position: sticky;
    top: 84px;
    align-self: start;
    max-height: calc(100vh - 100px);
    overflow-y: auto;
    padding-right: 0.4rem;
  }
  .docs-home {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--ink);
    font-size: 0.95rem;
    margin-bottom: 1.3rem;
    letter-spacing: -0.2px;
  }
  .docs-home-mark { color: var(--veil); }
  .nav-section { margin-bottom: 1.35rem; }
  .nav-title {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--mist-2);
    margin: 0 0 0.55rem;
  }
  .docs-nav ul { list-style: none; margin: 0; padding: 0; }
  .nav-link {
    display: block;
    color: var(--mist);
    font-size: 0.9rem;
    padding: 0.34em 0.7em;
    border-radius: 7px;
    border-left: 2px solid transparent;
    line-height: 1.4;
  }
  .nav-link:hover { color: var(--ink); background: rgba(255, 255, 255, 0.03); }
  .nav-link.active {
    color: var(--ink);
    background: var(--grad-veil);
    border-left-color: var(--veil);
  }

  .content { min-width: 0; max-width: 760px; }
  .content-head { margin-bottom: 1.6rem; }
  .content-head h1 {
    font-size: clamp(2rem, 4.5vw, 2.9rem);
    margin: 0.35rem 0 0;
  }
  .content-lede {
    font-size: 1.08rem;
    color: var(--mist);
    margin: 0.9rem 0 0;
    max-width: 62ch;
  }

  /* prose typography for slotted docs content */
  .prose :global(h2) {
    margin-top: 2.4rem;
    padding-top: 0.4rem;
    font-size: 1.55rem;
    scroll-margin-top: 80px;
  }
  .prose :global(h3) {
    margin-top: 1.8rem;
    font-size: 1.1rem;
    color: var(--ink);
    scroll-margin-top: 80px;
  }
  .prose :global(p) { color: var(--mist); }
  .prose :global(a) { color: var(--cyan); border-bottom: 1px solid transparent; }
  .prose :global(a:hover) { border-bottom-color: var(--cyan); }
  .prose :global(ul), .prose :global(ol) { color: var(--mist); padding-left: 1.2rem; }
  .prose :global(li) { margin: 0.3rem 0; }
  .prose :global(li::marker) { color: var(--veil); }
  .prose :global(strong) { color: var(--ink); }
  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 0.86em;
    background: rgba(139, 124, 255, 0.1);
    border: 1px solid var(--line);
    border-radius: 5px;
    padding: 0.08em 0.4em;
    color: var(--ink);
  }
  .prose :global(pre code), .prose :global(.cb code) {
    background: none;
    border: 0;
    padding: 0;
  }
  .prose :global(hr) { border: 0; border-top: 1px solid var(--line); margin: 2rem 0; }
  .prose :global(.eyebrow) { display: inline-block; margin-bottom: 0.4rem; }

  .pager {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 3rem;
    padding-top: 1.4rem;
    border-top: 1px solid var(--line);
  }
  .pager-link {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 0.7rem 1rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.015);
    min-width: 150px;
  }
  .pager-link.next { text-align: right; align-items: flex-end; }
  .pager-link:hover { border-color: var(--veil); }
  .pager-dir { font-size: 0.7rem; color: var(--mist-2); }
  .pager-label { color: var(--ink); font-family: var(--font-display); font-weight: 500; font-size: 0.95rem; }

  @media (max-width: 880px) {
    .docs { grid-template-columns: 1fr; gap: 1.4rem; }
    .sidebar {
      position: static;
      max-height: none;
      overflow: visible;
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 1rem 1.1rem;
      background: rgba(255, 255, 255, 0.012);
    }
  }
</style>
