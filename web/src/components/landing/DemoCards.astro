---
// Three doorways: Private Voting (veil) · AI AgentBoard (cyan) · SDK & Docs (neutral).
import { DEMO_CARDS } from "./landing-data.ts";
---
<section class="cards">
  <div class="container">
    <header class="cards-head">
      <span class="eyebrow">Where to go</span>
      <h2>Three ways in.</h2>
    </header>
    <div class="grid">
      {DEMO_CARDS.map((c) => (
        <a class={`card doorway a-${c.accent}`} href={c.href}>
          <span class:list={["badge", c.accent !== "neutral" && `badge-${c.accent}`]}>{c.badge}</span>
          <h3>{c.title}</h3>
          <p>{c.blurb}</p>
          <span class="go mono">{c.cta} <span aria-hidden="true">→</span></span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .cards { padding: clamp(2rem, 6vw, 4rem) 0; }
  .cards-head { margin-bottom: 1.8rem; }
  .cards-head h2 { margin: 0.4rem 0 0; }

  .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.1rem; }

  .doorway {
    display: flex; flex-direction: column; gap: 0.7rem; color: var(--ink);
    border-radius: var(--radius); transition: transform 0.18s ease, border-color 0.2s ease, box-shadow 0.25s ease;
  }
  .doorway h3 { margin: 0.2rem 0 0; font-size: 1.2rem; }
  .doorway p { margin: 0; color: var(--mist); font-size: 0.92rem; line-height: 1.6; }
  .doorway .go { margin-top: auto; padding-top: 0.7rem; font-size: 0.82rem; font-weight: 500; color: var(--mist); }
  .doorway:hover { transform: translateY(-4px); }
  .doorway:hover .go { color: var(--ink); }

  .a-veil:hover { border-color: rgba(139,124,255,0.55); box-shadow: var(--glow-veil); }
  .a-veil:hover .go { color: var(--veil); }
  .a-cyan:hover { border-color: rgba(61,224,230,0.55); box-shadow: var(--glow-cyan); }
  .a-cyan:hover .go { color: var(--cyan); }
  .a-neutral:hover { border-color: rgba(255,255,255,0.28); box-shadow: 0 0 0 1px rgba(255,255,255,0.22), 0 12px 40px -12px rgba(0,0,0,0.7); }

  @media (max-width: 860px) { .grid { grid-template-columns: 1fr; } }
</style>
