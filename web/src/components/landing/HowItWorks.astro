---
// How it works — 4 concise numbered steps: snapshot → sealed ZK vote → timelock reveal → agent swap.
import { HOW_STEPS } from "./landing-data.ts";
---
<section class="how">
  <div class="container">
    <header class="how-head">
      <span class="eyebrow">How it works</span>
      <h2>Four steps, no middlemen.</h2>
      <p>From the member roll to the executed swap — secured by math, not trust.</p>
    </header>
    <ol class="steps" role="list">
      {HOW_STEPS.map((s) => (
        <li class="step">
          <span class="n mono">{String(s.n).padStart(2, "0")}</span>
          <div class="step-body">
            <h3>{s.title}</h3>
            <p>{s.body}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .how { padding: clamp(3rem, 7vw, 5.5rem) 0; }
  .how-head { max-width: 56ch; margin-bottom: 2.2rem; }
  .how-head h2 { margin: 0.45rem 0 0.5rem; }
  .how-head p { color: var(--mist); }

  .steps { list-style: none; margin: 0; padding: 0; display: grid;
           grid-template-columns: repeat(4, 1fr); gap: 0; }
  .step { position: relative; padding: 1.5rem 1.4rem 1.5rem 0; border-top: 1px solid var(--line); }
  .step + .step { padding-left: 1.4rem; }
  .n {
    display: inline-block; font-size: 0.95rem; font-weight: 700;
    background: var(--grad-hero); -webkit-background-clip: text; background-clip: text; color: transparent;
    margin-bottom: 0.7rem;
  }
  .step h3 { font-size: 1rem; margin: 0 0 0.4rem; }
  .step p { margin: 0; font-size: 0.86rem; line-height: 1.55; color: var(--mist); }
  /* a hairline track linking the steps, fading violet→cyan */
  .steps::before { content: ""; grid-column: 1 / -1; height: 0; }

  @media (max-width: 900px) { .steps { grid-template-columns: repeat(2, 1fr); }
    .step:nth-child(-n+2) { border-top: 1px solid var(--line); }
    .step:nth-child(odd) { padding-left: 0; } .step:nth-child(even) { padding-left: 1.4rem; } }
  @media (max-width: 540px) { .steps { grid-template-columns: 1fr; }
    .step { padding-left: 0 !important; } }
</style>
