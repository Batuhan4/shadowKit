---
// Landing hero — "Vote in the shadows. Execute in the light." The octagon Seal motif sits behind
// the headline; CTAs route to the two live demos; a live testnet badge shows the real GovVault id.
import { CONFIG, short } from "../../lib/config.ts";
---
<section class="hero">
  <div class="container hero-inner">
    <!-- The Seal: an octagon with a keyhole, drawn once, glowing behind the copy -->
    <div class="seal" aria-hidden="true">
      <svg viewBox="0 0 240 240" width="100%" height="100%">
        <defs>
          <linearGradient id="seal-stroke" x1="0" y1="0" x2="240" y2="240">
            <stop offset="0" stop-color="var(--veil)"></stop>
            <stop offset="1" stop-color="var(--cyan)"></stop>
          </linearGradient>
        </defs>
        <g fill="none" stroke="url(#seal-stroke)" stroke-linejoin="round">
          <path class="ring ring-1" stroke-width="1.4" opacity="0.9"
            d="M78 18h84l60 60v84l-60 60H78l-60-60V78z"></path>
          <path class="ring ring-2" stroke-width="1" opacity="0.45"
            d="M92 44h56l48 48v56l-48 48H92l-48-48V92z"></path>
          <circle class="kh-ring" cx="120" cy="108" r="22" stroke-width="1.6"></circle>
          <path class="kh-stem" d="M120 130v34" stroke-width="3.2" stroke-linecap="round"></path>
        </g>
      </svg>
    </div>

    <span class="eyebrow reveal-up r0">ZK + AI governance · Stellar / Soroban</span>
    <h1 class="reveal-up r1">
      Vote in the shadows.<br />
      <span class="gradient-text">Execute in the light.</span>
    </h1>
    <p class="lede reveal-up r2">
      Members vote in total privacy — zero-knowledge proofs hide identity, weight, and direction, and
      the tally stays <b>sealed</b> behind a timelock until close. Then an LLM-bounded agent executes
      the approved action on-chain, gated by a policy it <b>mathematically cannot break</b>.
    </p>
    <div class="cta reveal-up r3">
      <a class="btn btn-primary" href="/demo/fund">Try ShadowFund <span aria-hidden="true">→</span></a>
      <a class="btn btn-ghost" href="/demo/agent">Watch AgentBoard</a>
    </div>
    <div class="live reveal-up r4">
      <span class="badge badge-green"><span class="dot" aria-hidden="true"></span> Live on Stellar testnet</span>
      <span class="mono gv">GovVault <a href={`${CONFIG.explorerBase}/contract/${CONFIG.govVaultId}`} target="_blank" rel="noopener">{short(CONFIG.govVaultId)}</a></span>
    </div>
  </div>
</section>

<style>
  .hero { position: relative; padding: clamp(4rem, 11vw, 8.5rem) 0 clamp(3rem, 7vw, 5.5rem); overflow: hidden; }
  .hero-inner { position: relative; max-width: 920px; }

  .seal {
    position: absolute; top: 50%; right: -2%; transform: translateY(-52%);
    width: clamp(280px, 42vw, 560px); aspect-ratio: 1; z-index: 0; pointer-events: none;
    filter: drop-shadow(0 0 40px rgba(139,124,255,0.25));
    opacity: 0; animation: sealIn 1.1s ease 0.15s forwards;
  }
  @keyframes sealIn { to { opacity: 0.85; } }
  .seal .ring-1 { animation: spin 60s linear infinite; transform-origin: 50% 50%; }
  .seal .ring-2 { animation: spin 90s linear infinite reverse; transform-origin: 50% 50%; }
  @keyframes spin { to { transform: rotate(360deg); } }

  .hero-inner > * { position: relative; z-index: 1; }
  h1 { margin: 0.7rem 0 0; }
  .lede { font-size: clamp(1.05rem, 1.7vw, 1.22rem); color: var(--mist); max-width: 62ch; margin: 1.5rem 0 2.1rem; }
  .lede b { color: var(--ink); font-weight: 600; }
  .cta { display: flex; gap: 0.8rem; flex-wrap: wrap; }

  .live { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; margin-top: 2rem; }
  .live .dot { width: 7px; height: 7px; border-radius: 50%; background: var(--green); box-shadow: 0 0 8px var(--green); animation: pulse 2.2s ease-in-out infinite; }
  @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.4; } }
  .gv { color: var(--mist-2); font-size: 0.82rem; }
  .gv a { color: var(--veil); }
  .gv a:hover { color: var(--ink); }

  /* staggered reveal */
  .reveal-up.r0 { animation-delay: 0s; }
  .reveal-up.r1 { animation-delay: 0.07s; }
  .reveal-up.r2 { animation-delay: 0.15s; }
  .reveal-up.r3 { animation-delay: 0.23s; }
  .reveal-up.r4 { animation-delay: 0.32s; }

  @media (max-width: 760px) {
    .seal { right: -22%; opacity: 0; }
    @keyframes sealIn { to { opacity: 0.4; } }
  }
</style>
