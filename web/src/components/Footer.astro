---
import { CONFIG, explorerContract, short } from "../lib/config.ts";
const contracts = [
  { label: "GovVault", id: CONFIG.govVaultId },
  { label: "Verifier", id: CONFIG.verifierId },
  { label: "AgentPolicy", id: CONFIG.agentPolicyId },
];
---
<footer class="ft">
  <div class="wrap ft-row">
    <div>
      <div class="ft-mark">Shadow<span class="mk-b">Kit</span></div>
      <p class="ft-tag muted">Vote in the shadows. Execute in the light.</p>
      <span class="tag tag-ok dot">Live on Stellar testnet</span>
    </div>
    <nav class="ft-links" aria-label="Footer">
      <a href="/demo/fund">ShadowFund</a>
      <a href="/demo/agent">AgentBoard</a>
      <a href="/docs">Docs</a>
      <a href="https://github.com/Batuhan4/shadowKit" target="_blank" rel="noopener">GitHub</a>
    </nav>
    <div class="ft-contracts">
      <div class="ft-h">Contracts</div>
      {contracts.map((c) => (
        <a class="mono" href={explorerContract(c.id)} target="_blank" rel="noopener">{c.label} · {short(c.id)}</a>
      ))}
    </div>
  </div>
</footer>

<style>
  .ft { border-top: 1px solid var(--line); margin-top: clamp(4rem, 8vw, 8rem); padding-block: clamp(2.5rem, 5vw, 4rem); background: var(--bg-2); }
  .ft-row { display: grid; grid-template-columns: 1.6fr 1fr 1fr; gap: clamp(1.5rem, 4vw, 3rem); align-items: start; }
  .ft-mark { font-family: var(--font-display); font-weight: 800; font-size: 1.25rem; color: var(--text); }
  .mk-b { color: var(--lime); }
  .ft-tag { margin: 0.4rem 0 0.8rem; font-size: 0.92rem; }
  .ft-h { font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted); margin-bottom: 0.8rem; }
  .ft-links { display: flex; flex-direction: column; gap: 0.5rem; }
  .ft-links a { color: var(--text-2); font-family: var(--font-mono); font-size: 0.85rem; }
  .ft-links a:hover { color: var(--lime); }
  .ft-contracts { display: flex; flex-direction: column; gap: 0.5rem; }
  .ft-contracts a { color: var(--muted); font-size: 0.78rem; }
  @media (max-width: 680px) { .ft-row { grid-template-columns: 1fr; gap: 1.8rem; } }
</style>
