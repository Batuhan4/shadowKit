---
// Site-wide top navigation. Pure Astro (no hydration). Brand mark = "The Seal" octagon + keyhole.
const links = [
  { href: "/", label: "Home" },
  { href: "/demo/fund", label: "ShadowFund" },
  { href: "/demo/agent", label: "AgentBoard" },
  { href: "/docs", label: "Docs" },
];
const path = Astro.url.pathname;
const isActive = (href: string) => (href === "/" ? path === "/" : path.startsWith(href));
---
<header class="nav">
  <div class="container nav-inner">
    <a class="brand" href="/" aria-label="ShadowKit home">
      <svg width="26" height="26" viewBox="0 0 32 32" fill="none" aria-hidden="true">
        <defs>
          <linearGradient id="sk" x1="0" y1="0" x2="32" y2="32">
            <stop offset="0" stop-color="#8b7cff"></stop>
            <stop offset="1" stop-color="#3de0e6"></stop>
          </linearGradient>
        </defs>
        <path d="M10 2h12l8 8v12l-8 8H10l-8-8V10z" stroke="url(#sk)" stroke-width="1.6" fill="rgba(139,124,255,0.08)"></path>
        <circle cx="16" cy="14" r="3.1" stroke="url(#sk)" stroke-width="1.6"></circle>
        <path d="M16 17v6" stroke="url(#sk)" stroke-width="1.6" stroke-linecap="round"></path>
      </svg>
      <span class="brand-word">Shadow<b>Kit</b></span>
    </a>

    <nav class="links" aria-label="Primary">
      {links.map((l) => (
        <a href={l.href} class:list={["link", { active: isActive(l.href) }]}>{l.label}</a>
      ))}
    </nav>

    <a class="gh" href="https://github.com/Batuhan4/shadowKit" target="_blank" rel="noopener" aria-label="GitHub repository">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.7.5.5 5.7.5 12c0 5.1 3.3 9.4 7.9 10.9.6.1.8-.2.8-.5v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.3-1.3-5.3-5.7 0-1.3.4-2.3 1.2-3.1-.1-.3-.5-1.5.1-3.1 0 0 1-.3 3.3 1.2a11.5 11.5 0 0 1 6 0C17 4.6 18 4.9 18 4.9c.6 1.6.2 2.8.1 3.1.8.8 1.2 1.8 1.2 3.1 0 4.4-2.7 5.4-5.3 5.7.4.4.8 1.1.8 2.2v3.3c0 .3.2.6.8.5 4.6-1.5 7.9-5.8 7.9-10.9C23.5 5.7 18.3.5 12 .5z"></path></svg>
    </a>
  </div>
</header>

<style>
  .nav { position: sticky; top: 0; z-index: 50; backdrop-filter: blur(14px);
         background: rgba(11,11,18,0.72); border-bottom: 1px solid var(--line); }
  .nav-inner { display: flex; align-items: center; gap: 1.2rem; height: 62px; }
  .brand { display: flex; align-items: center; gap: 0.55rem; color: var(--ink); font-family: var(--font-display); }
  .brand-word { font-weight: 500; letter-spacing: -0.3px; font-size: 1.05rem; }
  .brand-word b { font-weight: 700; color: var(--veil); }
  .links { display: flex; gap: 0.3rem; margin-left: auto; }
  .link { color: var(--mist); font-family: var(--font-display); font-weight: 500; font-size: 0.92rem;
          padding: 0.45em 0.8em; border-radius: 8px; }
  .link:hover { color: var(--ink); background: rgba(255,255,255,0.04); }
  .link.active { color: var(--ink); background: var(--grad-veil); }
  .gh { color: var(--mist); display: inline-flex; }
  .gh:hover { color: var(--ink); }
  @media (max-width: 620px) { .brand-word { display: none; } .link { padding: 0.4em 0.55em; font-size: 0.85rem; } }
</style>
