---
// API reference table. Renders rows of { name, type, desc } with a mono first column.
// `cols` overrides the headers; default = ["", "Type", "Description"].
// Usage:
//   <ApiTable rows={[{ name: "init(env, admin, ...)", type: "→ ()", desc: "..." }]} />
export interface ApiRow {
  name: string;
  type?: string;
  desc?: string;
}
interface Props {
  rows: ApiRow[];
  cols?: [string, string, string];
  caption?: string;
}
const { rows, cols = ["", "Type", "Description"], caption } = Astro.props;
---
<div class="api-wrap">
  {caption && <p class="api-caption">{caption}</p>}
  <table class="api">
    <thead>
      <tr>
        <th>{cols[0]}</th>
        <th>{cols[1]}</th>
        <th>{cols[2]}</th>
      </tr>
    </thead>
    <tbody>
      {rows.map((r) => (
        <tr>
          <td class="api-name mono">{r.name}</td>
          <td class="api-type mono">{r.type}</td>
          <td class="api-desc">{r.desc}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

<style>
  .api-wrap { margin: 1.1rem 0 1.6rem; }
  .api-caption {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--mist-2);
    margin: 0 0 0.5rem;
  }
  .api {
    width: 100%;
    border-collapse: collapse;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    overflow: hidden;
    font-size: 0.86rem;
  }
  .api thead th {
    text-align: left;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--mist-2);
    background: linear-gradient(180deg, var(--panel), var(--panel-2));
    padding: 0.55rem 0.85rem;
    border-bottom: 1px solid var(--line);
  }
  .api td {
    padding: 0.6rem 0.85rem;
    border-bottom: 1px solid var(--line);
    vertical-align: top;
  }
  .api tbody tr:last-child td { border-bottom: 0; }
  .api tbody tr:nth-child(odd) td { background: rgba(255, 255, 255, 0.012); }
  .api-name { color: var(--veil); white-space: nowrap; }
  .api-type { color: var(--cyan); font-size: 0.8rem; }
  .api-desc { color: var(--mist); }
  @media (max-width: 720px) {
    .api, .api thead, .api tbody, .api th, .api td, .api tr { display: block; }
    .api thead { display: none; }
    .api tr { border-bottom: 1px solid var(--line); padding: 0.4rem 0; }
    .api td { border: 0; padding: 0.25rem 0.85rem; }
    .api-name { white-space: normal; }
  }
</style>
