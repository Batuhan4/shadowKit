---
// Inline admonition for docs. type maps to a brand accent + glyph.
//   note (veil) · tip (cyan) · warn (gold) · ok (green) · danger (red)
interface Props {
  type?: "note" | "tip" | "warn" | "ok" | "danger";
  title?: string;
}
const { type = "note", title } = Astro.props;
const GLYPH: Record<string, string> = {
  note: "◆",
  tip: "✦",
  warn: "▲",
  ok: "✓",
  danger: "■",
};
const HEADING: Record<string, string> = {
  note: "Note",
  tip: "Tip",
  warn: "Heads up",
  ok: "Verified",
  danger: "Danger",
};
---
<aside class={`callout callout-${type}`} role="note">
  <span class="callout-glyph" aria-hidden="true">{GLYPH[type]}</span>
  <div class="callout-body">
    <p class="callout-title">{title ?? HEADING[type]}</p>
    <div class="callout-content"><slot /></div>
  </div>
</aside>

<style>
  .callout {
    display: flex;
    gap: 0.8rem;
    margin: 1.2rem 0;
    padding: 0.95rem 1.05rem;
    border: 1px solid var(--line);
    border-left-width: 3px;
    border-radius: var(--radius-sm);
    background: rgba(255, 255, 255, 0.018);
  }
  .callout-glyph {
    font-size: 0.85rem;
    line-height: 1.7;
    flex: none;
  }
  .callout-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.86rem;
    margin: 0 0 0.25rem;
    color: var(--ink);
    letter-spacing: 0.01em;
  }
  .callout-content :global(p) {
    margin: 0;
    font-size: 0.92rem;
    color: var(--mist);
  }
  .callout-content :global(p + p) { margin-top: 0.5rem; }
  .callout-content :global(code) { color: var(--ink); }

  .callout-note { border-left-color: var(--veil); }
  .callout-note .callout-glyph { color: var(--veil); }
  .callout-tip { border-left-color: var(--cyan); }
  .callout-tip .callout-glyph { color: var(--cyan); }
  .callout-warn { border-left-color: var(--gold); }
  .callout-warn .callout-glyph { color: var(--gold); }
  .callout-ok { border-left-color: var(--green); }
  .callout-ok .callout-glyph { color: var(--green); }
  .callout-danger { border-left-color: var(--red); }
  .callout-danger .callout-glyph { color: var(--red); }
</style>
