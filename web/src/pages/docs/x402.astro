---
import DocsLayout from "../../layouts/DocsLayout.astro";
import CodeBlock from "../../components/docs/CodeBlock.astro";
import Callout from "../../components/docs/Callout.astro";
import ApiTable from "../../components/docs/ApiTable.astro";

const pkgRows = [
  { name: "@shadowkit/x402-shared", type: "library", desc: "DRY Stellar resource-server construction + local test facilitator + auto-paying fetch." },
  { name: "@shadowkit/x402-premium-data", type: "service", desc: "x402-protected market price + signal — the endpoint the AGENT pays." },
  { name: "@shadowkit/x402-api", type: "service", desc: "x402-protected verify/execute — the endpoints ShadowKit SELLS to other agents." },
];

const sharedApi = [
  { name: "buildStellarResourceServer(cfg)", type: "→ RequestHandler", desc: "Wires x402ResourceServer + ExactStellarScheme + paymentMiddleware for the given routes." },
  { name: "startTestFacilitator(cfg)", type: "→ Promise", desc: "Stands up a real x402Facilitator over HTTP (createFacilitatorRouter) for local round-trip tests." },
  { name: "makeX402Fetch(signerSecret, network)", type: "→ fetch", desc: "Client-side auto-paying fetch — answers the 402 challenge and retries (used by the agent + tests)." },
  { name: "StellarNetwork", type: "type", desc: "\"stellar:testnet\" | \"stellar:pubnet\" (CAIP-2)." },
];
---
<DocsLayout
  title="x402 services"
  eyebrow="SDK reference"
  description="Real HTTP 402 payments on Stellar — both directions. The agent pays for premium data; ShadowKit sells verify/execute. Settlement is a USDC (SEP-41 SAC) transfer."
  href="/docs/x402"
>
  <p>
    ShadowKit is an x402 participant on both sides: the agent <strong>pays</strong> for market data, and
    ShadowKit <strong>sells</strong> proof-verification and execution to other agents. Both use the real
    <code>@x402/stellar</code> mechanism — no faked 200s.
  </p>
  <ApiTable rows={pkgRows} cols={["Package", "Kind", "Role"]} />

  <h2>@shadowkit/x402-shared</h2>
  <p>The shared construction layer so every service builds the resource server the same way.</p>
  <ApiTable rows={sharedApi} cols={["Export", "Returns", "Description"]} />

  <h2>Agent pays — premium-data</h2>
  <p>
    A <code>GET /market/:pair</code> endpoint behind the x402 paywall. It returns 402 until paid, then
    <code>&#123; pair, price, signal &#125;</code>. The agent's <code>DataClient</code> answers the challenge
    automatically.
  </p>
  <CodeBlock lang="ts" file="x402-services/premium-data/src/server.ts" code={`import { createPremiumDataServer } from "@shadowkit/x402-premium-data";

const app = createPremiumDataServer({
  payTo: RESOURCE_SERVER_ADDRESS,   // G... that receives USDC
  network: "stellar:testnet",
  priceUsdc: "0.01",
  facilitatorUrl,                   // OZ Channels facilitator / local test facilitator
});
app.listen(4021);
// GET /market/XLM-USDC → 402 until paid → { pair, price, signal }`} />

  <h2>ShadowKit sells — shadowkit-api</h2>
  <p>
    <code>POST /verify</code> runs the real off-chain Groth16 verification; <code>POST /execute</code> gates
    on <code>GovVault.is_approved</code> and, only if approved, kicks the agent and returns the swap tx
    hash. Both sit behind the same paywall.
  </p>
  <CodeBlock lang="ts" file="x402-services/shadowkit-api/src/server.ts" code={`import { createShadowKitApiServer } from "@shadowkit/x402-api";

const app = createShadowKitApiServer({
  payTo: RESOURCE_SERVER_ADDRESS,
  network: "stellar:testnet",
  priceUsdc: "0.05",
  facilitatorUrl,
  govVaultId, rpcUrl,
});
// POST /verify  { proof, publicSignals } → { valid }
// POST /execute { proposalId }           → { accepted, proposalId, txHash }  (403 if not approved)`} />

  <Callout type="warn" title="Real settlement needs three funded accounts">
    <p>
      A Stellar x402 settlement is a USDC (SEP-41 SAC) transfer, not an XLM payment. It needs three
      distinct testnet keypairs: the <strong>client/payer</strong> (XLM + USDC trustline + USDC), the
      <strong>facilitator</strong> (XLM, submits the settle tx), and the <strong>resource server / payTo</strong>
      (XLM + USDC trustline). A single self-paying XLM account cannot settle.
    </p>
  </Callout>

  <h2>Client side — paying a 402</h2>
  <CodeBlock lang="ts" code={`import { makeX402Fetch } from "@shadowkit/x402-shared";

const pay = makeX402Fetch(CLIENT_SECRET, "stellar:testnet");
const res = await pay("https://.../market/XLM-USDC"); // auto-answers the 402, retries, returns 200
const data = await res.json();`} />

  <Callout type="note" title="Default USDC (testnet)">
    <p>
      The default asset is the testnet USDC SEP-41 SAC
      (<code>CBIELTK6…DAMA</code>, 7 decimals). Testnet USDC is minted from the Circle faucet; the deploy
      bootstrap adds the trustlines and balances.
    </p>
  </Callout>
</DocsLayout>
