---
import DocsLayout from "../../layouts/DocsLayout.astro";
import CodeBlock from "../../components/docs/CodeBlock.astro";
import Callout from "../../components/docs/Callout.astro";
import ApiTable from "../../components/docs/ApiTable.astro";
import { CONFIG, explorerContract, explorerAccount, short } from "../../lib/config.ts";

// LIVE testnet deployment — sourced from CONFIG (web/src/lib/contracts.json), generated post-deploy.
const deployed = [
  { name: "GovVault", crate: "gov-vault", id: CONFIG.govVaultId, role: "Sealed-vote storage, proof verification, quorum + reveal, approval gate." },
  { name: "Groth16Verifier", crate: "groth16-verifier", id: CONFIG.verifierId, role: "On-chain Groth16 (BLS12-381) proof verification." },
  { name: "AgentPolicy", crate: "agent-policy", id: CONFIG.agentPolicyId, role: "OZ smart-account policy — the lock that gates agent swaps." },
  { name: "FallbackAMM", crate: "fallback-amm", id: CONFIG.ammId, role: "Constant-product USDC/XLM pool (SwapVenue impl)." },
  { name: "USDC (SAC)", crate: "self-issued", id: CONFIG.usdcId, role: "Treasury asset — self-issued test USDC Stellar Asset Contract." },
  { name: "wXLM (SAC)", crate: "native", id: CONFIG.wxlmId, role: "Wrapped XLM SAC — the pool's counter-asset." },
];

const govRows = [
  { name: "init(env, admin, verifier, merkle_root, treasury_asset, quorum_cfg)", type: "→ ()", desc: "Initialize once. Quorum default: min_voters=3, yes_must_exceed_no=true." },
  { name: "create_proposal(env, action_spec, cap, deadline)", type: "→ u32", desc: "New sequential proposal id. cap bounds the action amount; deadline is a ledger-time unix second." },
  { name: "cast_vote(env, id, proof, pub_signals, sealed_ciphertext)", type: "→ ()", desc: "Verify proof, check nullifier + proposalId binding + merkle root, store the sealed vote. Exposes no tally." },
  { name: "close_and_reveal(env, id, revealed_yes_w, revealed_no_w, decryptions)", type: "→ ()", desc: "After deadline: re-aggregate submitted decryptions against stored ciphertexts → Approved | Rejected." },
  { name: "is_approved(env, id)", type: "→ bool", desc: "True iff status == Approved (read by AgentPolicy during auth)." },
  { name: "cap_of(env, id) / action_of(env, id)", type: "→ i128 / ActionSpec", desc: "Approved spending cap and the approved ActionSpec (read by AgentPolicy)." },
  { name: "proposal(env, id)", type: "→ ProposalView", desc: "Full read model. weighted_yes/no are None until revealed." },
  { name: "votes_cast(env, id)", type: "→ u32", desc: "Participation count (safe — no direction)." },
  { name: "set_executor(env, executor)", type: "→ ()", desc: "Admin-auth: configure the AgentPolicy address allowed to call mark_executed." },
  { name: "mark_executed(env, id)", type: "→ ()", desc: "Single-shot replay guard; only callable by the configured executor. Sets status → Executed." },
];

const govErrors = [
  { name: "NullifierUsed = 7", type: "error", desc: "Double-vote: this nullifier was already cast." },
  { name: "WrongProposalId = 8", type: "error", desc: "Proof/nullifier bound to a different proposalId (replay)." },
  { name: "InvalidProof = 9", type: "error", desc: "Groth16 verify returned false." },
  { name: "StaleMerkleRoot = 10", type: "error", desc: "Public merkleRoot signal != stored snapshot root." },
  { name: "DeadlinePassed = 5 / DeadlineNotReached = 6", type: "error", desc: "cast_vote after deadline / close before deadline." },
  { name: "RevealMismatch = 13", type: "error", desc: "Submitted decryptions inconsistent with the committed ciphertexts." },
  { name: "NotApproved = 15", type: "error", desc: "Action requires an Approved proposal." },
];

const policyGates = [
  { name: "(a) approved", type: "NotApproved = 2", desc: "GovVault.is_approved(proposal_id) must be true." },
  { name: "(b) not executed", type: "AlreadyExecuted = 3", desc: "Proposal must not already be Executed (single-shot)." },
  { name: "(c) target", type: "WrongTarget = 4", desc: "Context contract must equal approved_amm." },
  { name: "(d) asset_in", type: "WrongAsset = 5", desc: "asset_in must equal treasury_asset AND action.asset_in." },
  { name: "(e) cap", type: "OverCap = 6", desc: "amount_in must be ≤ GovVault.cap_of(proposal_id)." },
  { name: "(f) asset_out", type: "WrongAssetOut = 10", desc: "asset_out must equal action.asset_out (no rerouting to an unapproved token)." },
  { name: "single context", type: "MultiCall = 8", desc: "More than one Contract context in the auth batch is rejected." },
];

const ammRows = [
  { name: "init(env, asset_a, asset_b)", type: "→ ()", desc: "Set the two pool assets (once)." },
  { name: "add_liquidity(env, from, amount_a, amount_b)", type: "→ ()", desc: "Deposit liquidity (from must auth); updates reserves." },
  { name: "swap(env, asset_in, amount_in, min_out, to)", type: "→ i128", desc: "Constant-product (x·y=k) swap, 0.3% fee. Reverts SlippageExceeded if out < min_out. Implements SwapVenue." },
  { name: "reserves(env)", type: "→ (i128, i128)", desc: "Current (reserve_a, reserve_b). Implements SwapVenue." },
];
---
<DocsLayout
  title="Contracts"
  eyebrow="SDK reference"
  description="The Soroban smart contracts, deployed live on Stellar testnet. Every address below resolves on Stellar Explorer."
  href="/docs/contracts"
>
  <p>
    ShadowKit ships six Cargo crates. The contracts hold no developer trust: <code>GovVault</code>
    verifies proofs and exposes an approval gate; <code>AgentPolicy</code> is the on-chain lock that
    refuses any off-spec agent action.
  </p>

  <Callout type="ok" title="Deployed & live on testnet">
    <p>
      These are the current testnet ids from the post-deploy config. Click any address to open it on
      Stellar Explorer. The treasury/admin account is{" "}
      <a href={explorerAccount(CONFIG.treasuryAddr)} target="_blank" rel="noopener">{short(CONFIG.treasuryAddr)}</a>.
    </p>
  </Callout>

  <h2>Live deployment</h2>
  <div class="contract-list">
    {deployed.map((c) => (
      <a class="contract-row card" href={explorerContract(c.id)} target="_blank" rel="noopener">
        <div class="contract-head">
          <span class="contract-name">{c.name}</span>
          <span class="badge badge-cyan">{c.crate}</span>
        </div>
        <p class="contract-role">{c.role}</p>
        <span class="contract-id mono">{c.id}</span>
      </a>
    ))}
  </div>

  <h2>GovVault — <code>gov-vault</code></h2>
  <p>
    Holds no funds. Stores sealed votes and exposes no tally before close. Its <code>ProposalClosed</code>
    event is what the agent watcher subscribes to.
  </p>
  <ApiTable rows={govRows} cols={["Entrypoint", "Returns", "Description"]} caption="Public entrypoints" />
  <ApiTable rows={govErrors} cols={["GovError", "Kind", "Meaning"]} caption="Selected errors (the negative-test surface)" />

  <h2>Groth16Verifier — <code>groth16-verifier</code></h2>
  <p>
    Stateless BLS12-381 Groth16 verifier; the verification key is compiled in. The convenience
    <code>verify(proof, pub_signals)</code> loads the embedded VK and checks the proof.
  </p>
  <CodeBlock lang="rust" code={`// pub_signals order is BINDING:
//   [merkleRoot, nullifier, proposalId, sealedCommitmentHash]
pub fn verify(env: Env, proof: Proof, pub_signals: Vec<Fr>) -> bool;`} />

  <h2>AgentPolicy — <code>agent-policy</code> (the lock)</h2>
  <p>
    An OpenZeppelin smart-account custom policy (crate <code>stellar-accounts</code>, git tag <code>v0.8.0-rc.1</code> — soroban-sdk 26). The treasury
    <em>is</em> this smart-account wallet. Its <code>enforce()</code> cross-reads <code>GovVault</code> and
    authorizes a swap only if every gate below passes — otherwise it panics with a typed
    <code>PolicyError</code>.
  </p>
  <ApiTable rows={policyGates} cols={["Gate", "Reject code", "Rule"]} caption="The enforce() gates" />
  <Callout type="danger" title="Defense in depth">
    <p>
      The agent's client-side executor also re-checks the cap before signing, and <code>GovVault</code>
      enforces single-shot execution via <code>mark_executed</code>. A hallucinating agent cannot move
      funds: the only call the policy ever authorizes is <code>swap</code> on the approved venue, with the
      approved asset, under the approved cap, to the approved output.
    </p>
  </Callout>

  <h2>FallbackAMM &amp; SwapVenue — <code>fallback-amm</code> / <code>swap-venue</code></h2>
  <p>
    <code>SwapVenue</code> is the venue-agnostic interface (<code>swap</code> + <code>reserves</code>) that
    every venue satisfies; <code>AgentPolicy</code> only ever authorizes <code>swap</code> on the configured
    venue. <code>FallbackAMM</code> is a constant-product USDC/XLM pool guaranteeing demo liquidity.
  </p>
  <ApiTable rows={ammRows} cols={["Entrypoint", "Returns", "Description"]} />

  <Callout type="note" title="Venue switch, not a code fork">
    <p>
      A Soroswap adapter satisfies the same <code>SwapVenue</code> trait; selection is a config switch
      (<code>SWAP_VENUE=fallback|soroswap</code>), never a branch in <code>AgentPolicy</code>.
    </p>
  </Callout>
</DocsLayout>

<style>
  .contract-list { display: grid; gap: 0.8rem; margin: 1rem 0 1.4rem; }
  .contract-row {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    transition: border-color 0.18s ease, transform 0.12s ease;
  }
  .contract-row:hover { border-color: var(--cyan); transform: translateY(-2px); }
  .contract-head { display: flex; align-items: center; gap: 0.6rem; }
  .contract-name { font-family: var(--font-display); font-weight: 600; color: var(--ink); font-size: 1.02rem; }
  .contract-role { margin: 0; font-size: 0.88rem; color: var(--mist); }
  .contract-id { font-size: 0.74rem; color: var(--mist-2); word-break: break-all; }
</style>
