---
// /demo/fund — ShadowFund: the private community-fund voting demo (the Hack-Privacy showcase).
// Members connect a Stellar wallet, cast a SEALED weighted vote (REAL client-side ZK proof hides
// identity/weight/direction; REAL tlock hides the running tally), then Close & Reveal runs the tlock
// reveal -> close_and_reveal on-chain -> the winning project receives the USDC pool. Fully live on
// testnet (no replay fallback). The interactive surface is the FundApp React island.
import Layout from "../../layouts/Layout.astro";
import { FundApp } from "../../components/fund/FundApp";
import { CONFIG, explorerContract, short } from "../../lib/config";
import type { FundProject } from "../../components/fund/FundProjectGrid";

// Candidate community-fund projects (SCF-styled). ONE is the LIVE on-chain round (live:true) — voting
// targets the deployed GovVault proposal below; the rest are display candidates ("coming soon").
const PROPOSAL_ID = 0;
const POOL_USDC = "10000";
const projects: FundProject[] = [
  {
    id: "shadowpay",
    name: "ShadowPay",
    category: "Payments",
    askUsdc: POOL_USDC,
    blurb: "Privacy-first mobile wallet for Stellar — sealed balances, shielded transfers.",
    live: true,
  },
  {
    id: "merkle-id",
    name: "MerkleID",
    category: "Identity",
    askUsdc: "7500",
    blurb: "Self-sovereign identity anchored to a Merkle snapshot on Soroban.",
    live: false,
  },
  {
    id: "aurora-amm",
    name: "Aurora AMM",
    category: "DeFi",
    askUsdc: "12000",
    blurb: "MEV-resistant AMM with timelock-batched order reveal.",
    live: false,
  },
  {
    id: "lumen-grants",
    name: "Lumen Grants",
    category: "Public goods",
    askUsdc: "5000",
    blurb: "Quadratic funding rounds with ZK-private contributions.",
    live: false,
  },
];

// The "how a sealed vote works" ledger — one line per step, mono index, minimal copy.
const steps = [
  {
    k: "PROVE",
    t: "Prove membership privately",
    d: "snarkjs builds a Groth16 proof that you're in the voter snapshot — in your browser. No address, weight or direction leaves the device.",
  },
  {
    k: "SEAL",
    t: "Timelock-seal the choice",
    d: "Your (weight, direction) is tlock-encrypted to a future drand round — genuinely undecryptable until close. The chain stores only ciphertext + a commitment.",
  },
  {
    k: "CAST",
    t: "Cast on-chain, tally sealed",
    d: "GovVault verifies the proof on-chain and records the sealed vote. Only a participation count is exposed — never the running tally.",
  },
  {
    k: "REVEAL",
    t: "Reveal & disburse",
    d: "After close, every sealed vote is tlock-decrypted and re-aggregated on-chain. If approved, the winning project receives the USDC pool.",
  },
];
---

<Layout
  title="ShadowFund — private community-fund voting · ShadowKit"
  description="Vote on community-fund projects privately: a real client-side zero-knowledge proof hides your identity, weight and direction, and a timelock seal keeps the running tally invisible until close. Live on Stellar testnet."
>
  <!-- HERO -->
  <section class="hero wrap">
    <p class="eyebrow rise">Hack-Privacy showcase · live on testnet</p>
    <h1 class="rise">Vote in the shadows.<br />Fund in the <span class="lit">light</span>.</h1>
    <p class="lede hero-lede rise">
      A community-fund round where whales can&apos;t see which way it&apos;s going. Each ballot is a real
      zero-knowledge proof — identity, weight and direction hidden — and the running tally is
      timelock-sealed until close. Then the seal breaks, the winner is revealed, the pool is disbursed
      on-chain.
    </p>
    <div class="hero-meta mono rise">
      <span class="tag tag-lime">ZK membership proof</span>
      <span class="tag">tlock · drand seal</span>
      <span class="tag">on-chain reveal</span>
      <a class="hero-contract" href={explorerContract(CONFIG.govVaultId)} target="_blank" rel="noopener">
        GovVault · {short(CONFIG.govVaultId)} ↗
      </a>
    </div>
  </section>

  <section class="app wrap">
    <!-- client:only — the island needs the browser (wallet, snarkjs/wasm, tlock, RPC). -->
    <FundApp client:only="react" projects={projects} proposalId={PROPOSAL_ID} poolUsdc={POOL_USDC} />
  </section>

  <!-- HOW IT WORKS -->
  <section class="how wrap">
    <p class="eyebrow">The mechanism</p>
    <h2 class="how-h">How a sealed vote works</h2>
    <ol class="ledger">
      {steps.map((s, i) => (
        <li>
          <span class="idx">0{i + 1} / {s.k}</span>
          <div>
            <h3>{s.t}</h3>
            <p class="muted">{s.d}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>
</Layout>

<style>
  .hero { padding-block: clamp(3rem, 7vw, 6rem) clamp(1.6rem, 3vw, 2.6rem); }
  .hero h1 { max-width: 16ch; }
  .lit { color: var(--lime); }
  .hero-lede { margin: 1.4rem 0 1.8rem; max-width: 58ch; }
  .hero-meta { display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap; }
  .hero-contract { color: var(--text-2); font-size: 0.78rem; letter-spacing: 0.02em; }
  .hero-contract:hover { color: var(--lime); text-decoration: none; }

  .rise:nth-child(2){animation-delay:.05s}.rise:nth-child(3){animation-delay:.1s}.rise:nth-child(4){animation-delay:.15s}

  .app { padding-block: clamp(1rem, 2vw, 1.6rem) clamp(1.4rem, 3vw, 2.4rem); }

  .how { padding-block: clamp(2.4rem, 5vw, 4.5rem) clamp(2.4rem, 5vw, 4rem); }
  .how-h { margin-bottom: clamp(1.4rem, 3vw, 2rem); font-size: clamp(1.6rem, 2.6vw, 2.4rem); }
</style>
