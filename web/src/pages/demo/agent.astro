---
import Layout from "../../layouts/Layout.astro";
import { AgentRunPanel } from "../../components/agent/AgentRunPanel.tsx";
import { CONFIG, short, explorerContract, explorerAccount } from "../../lib/config.ts";

const steps = [
  {
    tag: "GOV",
    title: "Read the vote",
    body: "Reads GovVault on testnet. If the proposal is not APPROVED, it refuses — 403, no transaction.",
  },
  {
    tag: "X402",
    title: "Pay for data",
    body: "Pays this site's premium-data endpoint over x402 (USDC) to fetch the quote it reasons over.",
  },
  {
    tag: "PLAN",
    title: "Bounded plan",
    body: "Gemini (server-side, key never in the browser) returns a structured plan: action, amountIn, minOut.",
  },
  {
    tag: "POLICY",
    title: "Gate the plan",
    body: "Checked against the on-chain cap, assets, and approval. A hallucinated or over-cap plan is BLOCKED.",
  },
  {
    tag: "CHAIN",
    title: "Execute in the light",
    body: "Only an allowed plan is signed by the executor key and submitted on-chain — real tx, real balances.",
  },
];

// anonymity-set divider strip — the signature motif (most dim, a few lit)
const STRIP = 28;
const stripLit = new Set([6, 13, 21]);
---

<Layout
  title="AgentBoard — ShadowKit"
  description="Watch a live AI agent read an approved DAO vote, pay for data over x402, plan a bounded swap with Gemini, get gated by an on-chain policy, and execute it on Stellar testnet — every run, fully live."
>
  <section class="wrap head">
    <div class="head-row">
      <span class="eyebrow rise">Bounded AI agent · live on testnet</span>
      <div class="badges rise">
        <span class="tag tag-lime">Agentic</span>
        <span class="tag tag-ok">No replay · fully live</span>
      </div>
    </div>
    <h1 class="rise">Execute in the <span class="lit">light</span>.</h1>
    <p class="lede rise">
      An AI agent carries out the DAO's <b>already-approved</b> decision — on a short leash. It pays for
      its own data over x402, reasons with Gemini, and every plan must clear an on-chain policy before a
      single stroop moves. A hallucinating agent literally <b>cannot</b> move funds the wrong way.
    </p>
  </section>

  <section class="wrap run">
    <AgentRunPanel client:load endpoint="/api/agent/execute" />
    <p class="run-note mono">
      $ runs server-side in a Cloudflare Pages Function — the Gemini key and the executor signing key
      never reach your browser.
    </p>
  </section>

  <!-- anonymity-set divider -->
  <div class="wrap">
    <div class="aset strip" style="--cols:28" aria-hidden="true">
      {Array.from({ length: STRIP }).map((_, i) => (
        <span class:list={["m", { lit: stripLit.has(i) }]}></span>
      ))}
    </div>
  </div>

  <section class="wrap explain">
    <p class="eyebrow">Bounded execution</p>
    <h2 class="explain-h">Two degrees of freedom.<br />Both <span class="lit">bounded</span>.</h2>
    <p class="explain-sub muted">
      The DAO already decided <i>whether</i> to act and <i>which</i> assets are in play. The agent only
      decides <i>how much</i> and the slippage floor — and two independent guards must both accept the
      plan, or nothing happens.
    </p>
    <ol class="ledger flow">
      {
        steps.map((s, i) => (
          <li>
            <span class="idx">0{i + 1} / {s.tag}</span>
            <div>
              <h3>{s.title}</h3>
              <p class="muted">{s.body}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="wrap wiring">
    <p class="eyebrow">Deployed &amp; live</p>
    <h2 class="wiring-h">Every run touches these contracts.</h2>
    <dl class="wiring-grid mono">
      <dt>GovVault</dt>
      <dd><a href={explorerContract(CONFIG.govVaultId)} target="_blank" rel="noopener">{short(CONFIG.govVaultId)} ↗</a></dd>
      <dt>AgentPolicy</dt>
      <dd><a href={explorerContract(CONFIG.agentPolicyId)} target="_blank" rel="noopener">{short(CONFIG.agentPolicyId)} ↗</a></dd>
      <dt>Swap venue (AMM)</dt>
      <dd><a href={explorerContract(CONFIG.ammId)} target="_blank" rel="noopener">{short(CONFIG.ammId)} ↗</a></dd>
      <dt>USDC (assetIn)</dt>
      <dd><a href={explorerContract(CONFIG.usdcId)} target="_blank" rel="noopener">{short(CONFIG.usdcId)} ↗</a></dd>
      <dt>wXLM (assetOut)</dt>
      <dd><a href={explorerContract(CONFIG.wxlmId)} target="_blank" rel="noopener">{short(CONFIG.wxlmId)} ↗</a></dd>
      <dt>Treasury</dt>
      <dd><a href={explorerAccount(CONFIG.treasuryAddr)} target="_blank" rel="noopener">{short(CONFIG.treasuryAddr)} ↗</a></dd>
    </dl>
  </section>
</Layout>

<style>
  .head { padding: clamp(2.4rem, 7vw, 5rem) 0 1.5rem; max-width: 56rem; }
  .head-row { display: flex; align-items: center; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
  .head h1 { max-width: 16ch; }
  .badges { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .head .lede { max-width: 60ch; margin: 1.4rem 0 0; }
  .head .lede b { color: var(--text); }
  .rise:nth-child(2) { animation-delay: 0.05s; }
  .rise:nth-child(3) { animation-delay: 0.1s; }

  .run { padding: clamp(1.4rem, 3vw, 2.2rem) 0 1rem; }
  .run-note { color: var(--muted); font-size: 0.76rem; margin-top: 1rem; }

  /* divider strip of marks */
  .strip { padding: clamp(1.4rem, 3vw, 2.2rem) 0; }
  .strip .m { aspect-ratio: 1; max-height: 14px; }

  .explain { padding: clamp(1.5rem, 3vw, 2.5rem) 0 1.5rem; }
  .explain-h { font-size: clamp(1.7rem, 3vw, 2.6rem); margin-bottom: 0.8rem; }
  .explain-sub { max-width: 60ch; margin: 0 0 clamp(1.6rem, 3vw, 2.4rem); }
  .explain-sub i { color: var(--text); font-style: italic; }
  .flow h3 { margin-bottom: 0.25rem; }
  .flow p { margin: 0; max-width: 56ch; }

  .wiring { padding: clamp(2rem, 4vw, 3rem) 0 clamp(3rem, 6vw, 4.5rem); }
  .wiring-h { font-size: clamp(1.5rem, 2.5vw, 2.2rem); margin-bottom: 1.3rem; }
  .wiring-grid {
    display: grid; grid-template-columns: max-content 1fr; gap: 0.55rem 1.6rem;
    border: 1px solid var(--line); border-radius: var(--radius-lg); padding: clamp(1.1rem, 2vw, 1.5rem) clamp(1.2rem, 2vw, 1.6rem);
    background: var(--panel); max-width: 600px; font-size: 0.82rem;
  }
  .wiring-grid dt { color: var(--muted); }
  .wiring-grid dd { margin: 0; }
  .wiring-grid dd a { color: var(--text-2); }
  .wiring-grid dd a:hover { color: var(--lime); }

  @media (max-width: 720px) {
    .head-row { align-items: flex-start; }
  }
</style>
