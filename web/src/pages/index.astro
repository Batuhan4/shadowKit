---
// ShadowKit landing — the front door. Cinematic, Astro-first, minimal JS. Sections are split into
// brand-consistent components under components/landing/, all driven by the testable landing-data model.
import Layout from "../layouts/Layout.astro";
import Hero from "../components/landing/Hero.astro";
import StoryFlow from "../components/landing/StoryFlow.astro";
import DemoCards from "../components/landing/DemoCards.astro";
import HowItWorks from "../components/landing/HowItWorks.astro";
import Tracks from "../components/landing/Tracks.astro";
import LiveStrip from "../components/landing/LiveStrip.astro";
import FinalCta from "../components/landing/FinalCta.astro";

const title = "ShadowKit — Vote in the shadows. Execute in the light.";
const description =
  "ZK + AI-agent governance infrastructure on Stellar / Soroban. Members vote privately with zero-knowledge proofs, the tally stays sealed behind a timelock until close, then an LLM-bounded agent executes the approved action on-chain — live on testnet.";
---
<Layout title={title} description={description}>
  <Hero />
  <hr class="divider container-divider" />
  <StoryFlow />
  <DemoCards />
  <HowItWorks />
  <Tracks />
  <LiveStrip />
  <FinalCta />
</Layout>

<style>
  .container-divider { width: 100%; max-width: var(--maxw); margin: 0 auto; opacity: 0.6; }
</style>
